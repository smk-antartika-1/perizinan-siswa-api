# Server Configuration
PORT=8000
NODE_ENV=production

# Public HTTPS domain handled by Caddy.
# Point this domain's DNS A record to the VPS public IP before starting Caddy.
APP_DOMAIN=api.example.com
APP_URL=https://api.example.com
HTTP_PORT=80
HTTPS_PORT=443

# Database Configuration (PostgreSQL)
# If PostgreSQL runs on the VPS host, use host.docker.internal from inside Docker.
DATABASE_URL=postgresql://postgres:postgres@host.docker.internal:5432/perizinan_siswa

# JWT Secrets (use long random values in production)
JWT_ACCESS_SECRET=change_me_access_with_long_random_value
JWT_REFRESH_SECRET=change_me_refresh_with_long_random_value
JWT_QR_SECRET=change_me_qr_with_long_random_value

# Token Expiration Settings
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=14
QR_TOKEN_TTL_MINUTES=30

# File Upload Directory (subfolders: avatars/, permissions/, imports/)
UPLOAD_DIR=uploads
