# Server Configuration
PORT=8000
NODE_ENV=production

# Public HTTPS host handled by Caddy.
# For direct public IP access, use the VPS IP and keep ACME_PROFILE=shortlived.
# For domain access, point the DNS A record to the VPS public IP.
APP_DOMAIN=202.134.242.37
APP_URL=https://202.134.242.37
ACME_EMAIL=admin@example.com
ACME_PROFILE=shortlived
HTTP_PORT=80
HTTPS_PORT=443

# Database Configuration (PostgreSQL)
# Docker Compose PostgreSQL service. Data is persisted in the postgres_data volume.
POSTGRES_DB=perizinan_siswa
POSTGRES_USER=sipas
POSTGRES_PASSWORD=change_me_database_password
DATABASE_URL=postgresql://sipas:change_me_database_password@db:5432/perizinan_siswa

# JWT Secrets (use long random values in production)
JWT_ACCESS_SECRET=change_me_access_with_long_random_value
JWT_REFRESH_SECRET=change_me_refresh_with_long_random_value
JWT_QR_SECRET=change_me_qr_with_long_random_value

# Token Expiration Settings
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=14
QR_TOKEN_TTL_MINUTES=30

# File Upload Directory (subfolders: avatars/, permissions/, imports/)
UPLOAD_DIR=uploads
